# Copy to /etc/indus-ure.env. Never commit real passwords or OAuth secrets.
PORT=8123
HOST=127.0.0.1
NODE_ENV=production
DATA_DIR=/var/lib/indus-ure
MEDIA_DIR=/var/lib/indus-ure/media
PUBLIC_BASE_URL=https://ure.indus.si

DATABASE_URL=postgresql://indus_ure:REPLACE_WITH_A_LONG_URL_ENCODED_PASSWORD@127.0.0.1:5432/indus_ure

# Google is used only for sign-in and Drive documents/backups. Sheets and Calendar are not used.
GOOGLE_CLIENT_ID=REPLACE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://ure.indus.si/api/google/callback
GOOGLE_DRIVE_TASKS_FOLDER_ID=1_z_1I_wX8-VR0K9rXj7BHRFwc--00Ul5
# Videos are streamed to this Drive folder and shared as viewer links. They do not use server disk.
GOOGLE_DRIVE_ATTACHMENTS_FOLDER_ID=1wsPGlRaN2M7biJK4zq3KnLSYRXzJX6S1
MAX_DRIVE_VIDEO_BYTES=209715200
GOOGLE_DRIVE_BACKUP_PARENT_FOLDER_ID=1_z_1I_wX8-VR0K9rXj7BHRFwc--00Ul5
GOOGLE_DRIVE_OWNER_EMAIL=bojan@indus.si

# Verified recovery backup. The archive excludes OAuth tokens, sessions and password hashes.
BACKUP_DIR=/var/backups/indus-ure
BACKUP_LOCAL_RETENTION_DAYS=30
BACKUP_OFFSITE_RETENTION_DAYS=90

# Optional alert email. Without SMTP, alerts remain visible in the boss menu only.
ALERT_SMTP_URL=smtps://username:password@smtp.example.si:465
ALERT_EMAIL_FROM=INDUS URE <noreply@indus.si>
ALERT_EMAIL_TO=bojan@indus.si
MONITOR_INTERVAL_MS=300000
MONITOR_MAX_RSS_MB=1800