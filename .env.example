# Kopiraj v /etc/indus-ure.env. Prava gesla in OAuth skrivnosti ne sodijo v Git.
PORT=8123
HOST=127.0.0.1
NODE_ENV=production
DATA_DIR=/var/lib/indus-ure
PUBLIC_BASE_URL=https://ure.indus.si

DATABASE_URL=postgresql://indus_ure:ZAMENJAJ_Z_DOLGIM_URL_ENCODED_GESLOM@127.0.0.1:5432/indus_ure

GOOGLE_CLIENT_ID=VSTAVI_CLIENT_ID
GOOGLE_CLIENT_SECRET=VSTAVI_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://ure.indus.si/api/google/callback
# Dvosmerni Google Calendar sync; najmanj 60000 ms.
GOOGLE_SYNC_INTERVAL_MS=60000

# Nove Google Dokumente in Preglednice aplikacija vedno ustvari z Bojanovim racunom.
# Mapa mora biti v Bojanovem My Drive (ne Shared Drive); uredniki se dedujejo iz mape.
GOOGLE_DRIVE_TASKS_FOLDER_ID=1_z_1I_wX8-VR0K9rXj7BHRFwc--00Ul5
GOOGLE_DRIVE_OWNER_EMAIL=bojan@indus.si

# Google Sheet je osnovna baza strank; Bojanov racun potrebuje pravico za urejanje.
GOOGLE_SHEETS_ID=1lQ2D1ZQlQyBZfih0B1-Jx-8UI58PK-vRzNbjW1V2MiM
GOOGLE_SHEETS_RANGE="'Baza Strank'!A:I"
